generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String
  role      String    @default("user")
  avatar    String?
  resetToken String?
  resetExpiry DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Wallet balance (for purchasing eSIM)
  walletBalance Float @default(0)

  // Affiliate fields
  affiliateCode     String?   @unique  // Unique referral code
  affiliateBalance  Float     @default(0) // Commission balance
  rank              String     @default("bronze") // bronze, silver, gold, diamond
  referredById      Int?      // User who referred this user
  referredBy        User?      @relation("ReferralRelation", fields: [referredById], references: [id])
  referrals         User[]    @relation("ReferralRelation") // Users referred by this user

  orders    Order[]
  cartItems CartItem[]
  commissionsReceived Commission[] @relation("CommissionReceiver")
  withdrawals Withdrawal[]
}

model Region {
  id        String   @id
  name      String
  emoji     String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  
  plans     Plan[]
}

model Country {
  id        String   @id
  name      String
  code      String   @unique
  slug      String   @unique  // For SEO URLs: thailand, south-korea, etc.
  emoji     String
  imageUrl  String?
  minPrice  Float?   // Lowest retailPriceUsd from plans in this country
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  
  plans     Plan[]
}

model Plan {
  id              String   @id
  name            String
  slug            String?
  packageCode     String   @unique
  description     String?
  destination     String
  
  regionId        String?
  region          Region?  @relation(fields: [regionId], references: [id])
  countryId       String?
  country         Country? @relation(fields: [countryId], references: [id])
  regionName      String?
  countryName     String?
  
  dataType        Int      @default(1)
  dataVolume      BigInt   @default(0)
  dataAmount      Int      @default(0)
  durationDays    Int      @default(30)
  durationUnit    String   @default("DAY")
  
  priceRaw        Int      @default(0)     // price * 10000 (10000 = $1.00)
  priceUsd        Float    @default(0)     // priceRaw / 10000
  retailPriceRaw  Int      @default(0)     // suggested retail price * 10000
  retailPriceUsd  Float    @default(0)     // retailPriceRaw / 10000
  currencyCode    String   @default("USD")
  
  speed           String?
  networkType     String?
  
  locationCode    String?
  locationLogo    String?
  locations       Json?
  coverageCount   Int      @default(1)
  
  smsStatus       Int      @default(0)
  activeType      Int      @default(1)
  supportTopUp    Boolean  @default(false)
  unusedValidTime Int      @default(0)
  ipExport        String?
  fupPolicy       String?
  
  locationNetworkList Json?
  
  isActive        Boolean  @default(true)
  isPopular       Boolean  @default(false)
  isBestSeller    Boolean  @default(false)
  isHot           Boolean  @default(false)
  supportTopUpType Int     @default(1) // 1 = no, 2 = yes, 3 = yes with period
  badge           String?
  priority        Int      @default(0)
  
  rawApiData      Json?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  orderItems      OrderItem[]
  topupPackages   TopupPackage[]

  @@index([regionId])
  @@index([countryId])
  @@index([isActive])
  @@index([dataType])
  @@index([locationCode])
}

model Order {
  id          Int      @id @default(autoincrement())
  userId      Int?
  user        User?    @relation(fields: [userId], references: [id])
  
  totalAmount Float
  currency    String   @default("USD")
  status      String   @default("pending")
  
  customerName    String?
  customerEmail   String?
  
  esimaccessOrderId     String?
  esimaccessOrderStatus String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems  OrderItem[]

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id              Int     @id @default(autoincrement())
  orderId         Int
  order           Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  planId          String?
  plan            Plan?   @relation(fields: [planId], references: [id])
  
  planName        String
  packageCode     String?
  quantity        Int     @default(1)
  price           Float
  
  esimIccid       String?
  esimEid         String?
  esimTranNo      String?
  esimQrCode      String?
  esimQrImage     String?
  esimLpaString   String?
  activationCode  String?
  
  totalVolume    Float?   // Total data volume in bytes (from API)
  smdpStatus      String?  // RELEASED, DOWNLOADED, INSTALLED, ENABLED
  esimStatus      String?  // INIT, GOT_RESOURCE, ACTIVATED, CANCEL, COMPLETED
  orderUsage      Float?   // Data usage in bytes
  lastUsageSync   DateTime?
  enabledAt       DateTime? // When eSIM was first enabled on device
  expiredAt       DateTime? // When eSIM data expires
  history        EsimHistory[] // History records

  @@index([esimIccid])
  @@index([esimTranNo])
  @@index([orderId])
}

model WebhookLog {
  id          Int      @id @default(autoincrement())
  orderNo     String?
  notifyType  String?
  orderStatus String?
  smdpStatus  String?
  payload     Json
  processedAt DateTime @default(now())

  @@index([orderNo])
  @@index([notifyType])
}

// eSIM history timeline - logs all webhook events for tracking
model EsimHistory {
  id          Int      @id @default(autoincrement())
  orderItemId Int      // Reference to OrderItem
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  eventType   String   // e.g., ORDER_CREATED, QR_GENERATED, DOWNLOADED, INSTALLED, ENABLED, USAGE_SYNC, EXPIRED
  rawData     Json     // Raw webhook payload
  description String? // Human-readable description (optional)
  createdAt   DateTime @default(now())

  @@index([orderItemId])
  @@index([createdAt])
}

model CartItem {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId    String?
  planName  String
  price     Float
  quantity  Int      @default(1)
  createdAt DateTime @default(now())

  @@index([userId])
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String
  image       String?
  category    String?
  author      String?
  isPublished Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([isPublished])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Affiliate Models
model Commission {
  id            Int       @id @default(autoincrement())
  referrerId    Int       // User who receives commission
  referrer      User      @relation("CommissionReceiver", fields: [referrerId], references: [id])
  buyerId       Int       // User who made the purchase
  orderId       Int       // The order that generated commission
  orderNo       String?   // Order number for display
  amount        Float     // Commission amount
  percentage    Float     // Commission percentage at time of order
  rank          String     // Rank at time of commission
  status        String     @default("pending") // pending, approved, paid
  createdAt     DateTime  @default(now())
  paidAt        DateTime?

  @@index([referrerId])
  @@index([orderId])
  @@index([status])
}

model Withdrawal {
  id              Int       @id @default(autoincrement())
  userId          Int
  user            User      @relation(fields: [userId], references: [id])
  amount          Float
  paymentMethod   String    // bank_transfer, paypal, etc.
  paymentDetails Json      // { bankName, accountNumber, accountName } or { email }
  status          String    @default("pending") // pending, approved, rejected, completed
  adminNote       String?
  createdAt       DateTime  @default(now())
  processedAt     DateTime?

  @@index([userId])
  @@index([status])
}

// Destination Management for Plans Page
model Destination {
  id          String   @id // country code like JP, KR, etc.
  name        String
  slug        String  @unique // URL slug like japan, south-korea
  emoji       String
  landmark    String? // Famous landmark name like "Tokyo Tower"
  imageUrl    String? // Image path like "/images/countries/jp.webp"
  isVisible   Boolean  @default(true)
  priority    Int      @default(0) // Sort order
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isVisible])
  @@index([priority])
}

// Region Management for Plans Page
model DestinationRegion {
  id          String   @id // region id like asia, europe, etc.
  name        String
  emoji       String
  imageUrl    String? // Image path for region
  isVisible   Boolean  @default(true)
  priority    Int      @default(0) // Sort order
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isVisible])
  @@index([priority])
}

// Top-up packages stored locally
model TopupPackage {
  id          Int      @id @default(autoincrement())
  planId     String?  // FK to Plan (optional - can be NULL for global top-ups)
  plan       Plan?    @relation(fields: [planId], references: [id])
  
  packageCode String   @unique // e.g., TOPUP_CN_1D, TOPUP_JP_500MB
  name       String?  // Display name
  price      Float    // Price in USD
  periodNum  Int     @default(1) // Days to add (1, 7, 30, etc.)
  type       String   @default("day") // "day" or "data"
  volume    BigInt   @default(0) // Data volume in bytes (0 for day-only top-ups)
  isActive   Boolean  @default(true)
  priority   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([planId])
  @@index([isActive])
}

// Promotional banners/popups model
model Promotion {
  id        Int      @id @default(autoincrement())
  title     String   // Title of the promotion
  imageUrl  String   // Image URL for the banner
  link     String?  // External link to navigate to
  isActive  Boolean  @default(true)
  priority  Int      @default(0) // Display order
  badge     String?  // Badge text like "50% OFF"
  startDate DateTime? // Promotion start date
  endDate   DateTime? // Promotion end date
  createdAt DateTime @default(now())
}
