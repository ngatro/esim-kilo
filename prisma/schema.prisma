generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("user")
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders    Order[]
  cartItems CartItem[]
}

model Region {
  id        String   @id
  name      String
  emoji     String
  countries Country[]
}

model Country {
  id        String   @id
  name      String
  code      String   @unique
  emoji     String
  regionId  String
  region    Region   @relation(fields: [regionId], references: [id])
  createdAt DateTime @default(now())
}

model Plan {
  id              String   @id
  name            String
  slug            String?
  packageCode     String   @unique
  description     String?
  destination     String
  
  regionId        String?   // "europe", "asia", "americas", etc - no FK
  countryId       String?   // "JP", "US", etc - no FK
  regionName      String?   // "Europe", "Asia" - for display
  countryName     String?   // "Japan", "United States" - for display
  
  dataType        Int      @default(1)
  dataVolume      BigInt   @default(0)
  dataAmount      Int      @default(0)
  durationDays    Int      @default(30)
  durationUnit    String   @default("DAY")
  
  priceRaw        Int      @default(0)     // price * 10000 (10000 = $1.00)
  priceUsd        Float    @default(0)     // priceRaw / 10000
  retailPriceRaw  Int      @default(0)     // suggested retail price * 10000
  retailPriceUsd  Float    @default(0)     // retailPriceRaw / 10000
  currencyCode    String   @default("USD")
  
  speed           String?
  networkType     String?
  
  locationCode    String?
  locations       Json?
  coverageCount   Int      @default(1)
  
  smsStatus       Int      @default(0)
  activeType      Int      @default(1)
  supportTopUp    Boolean  @default(false)
  unusedValidTime Int      @default(0)
  ipExport        String?
  fupPolicy       String?
  
  locationNetworkList Json?
  
  isActive        Boolean  @default(true)
  isPopular       Boolean  @default(false)
  isBestSeller    Boolean  @default(false)
  isHot           Boolean  @default(false)
  badge           String?
  priority        Int      @default(0)
  
  rawApiData      Json?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  orderItems      OrderItem[]

  @@index([regionId])
  @@index([countryId])
  @@index([isActive])
  @@index([dataType])
  @@index([locationCode])
}

model Order {
  id          Int      @id @default(autoincrement())
  userId      Int?
  user        User?    @relation(fields: [userId], references: [id])
  
  totalAmount Float
  currency    String   @default("USD")
  status      String   @default("pending")
  
  customerName    String?
  customerEmail   String?
  
  esimaccessOrderId     String?
  esimaccessOrderStatus String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems  OrderItem[]

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id              Int     @id @default(autoincrement())
  orderId         Int
  order           Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  planId          String?
  plan            Plan?   @relation(fields: [planId], references: [id])
  
  planName        String
  packageCode     String?   // saved directly for redundancy
  quantity        Int     @default(1)
  price           Float
  
  esimIccid       String?
  esimQrCode      String?
  esimQrImage     String?
  activationCode  String?
}

model CartItem {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId    String?
  planName  String
  price     Float
  quantity  Int      @default(1)
  createdAt DateTime @default(now())

  @@index([userId])
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String
  image       String?
  category    String?
  author      String?
  isPublished Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([isPublished])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}