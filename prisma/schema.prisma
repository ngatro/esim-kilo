generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String
  role      String    @default("user")
  avatar    String?
  resetToken String?
  resetExpiry DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders    Order[]
  cartItems CartItem[]
}

model Region {
  id        String   @id
  name      String
  emoji     String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  
  plans     Plan[]
}

model Country {
  id        String   @id
  name      String
  code      String   @unique
  emoji     String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  
  plans     Plan[]
}

model Plan {
  id              String   @id
  name            String
  slug            String?
  packageCode     String   @unique
  description     String?
  destination     String
  
  regionId        String?
  region          Region?  @relation(fields: [regionId], references: [id])
  countryId       String?
  country         Country? @relation(fields: [countryId], references: [id])
  regionName      String?
  countryName     String?
  
  dataType        Int      @default(1)
  dataVolume      BigInt   @default(0)
  dataAmount      Int      @default(0)
  durationDays    Int      @default(30)
  durationUnit    String   @default("DAY")
  
  priceRaw        Int      @default(0)     // price * 10000 (10000 = $1.00)
  priceUsd        Float    @default(0)     // priceRaw / 10000
  retailPriceRaw  Int      @default(0)     // suggested retail price * 10000
  retailPriceUsd  Float    @default(0)     // retailPriceRaw / 10000
  currencyCode    String   @default("USD")
  
  speed           String?
  networkType     String?
  
  locationCode    String?
  locationLogo    String?
  locations       Json?
  coverageCount   Int      @default(1)
  
  smsStatus       Int      @default(0)
  activeType      Int      @default(1)
  supportTopUp    Boolean  @default(false)
  unusedValidTime Int      @default(0)
  ipExport        String?
  fupPolicy       String?
  
  locationNetworkList Json?
  
  isActive        Boolean  @default(true)
  isPopular       Boolean  @default(false)
  isBestSeller    Boolean  @default(false)
  isHot           Boolean  @default(false)
  supportTopUp    Boolean  @default(false) // Whether this plan supports top-up (legacy)
  supportTopUpType Int     @default(1) // 1 = no, 2 = yes, 3 = yes with period
  badge           String?
  priority        Int      @default(0)
  
  rawApiData      Json?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  orderItems      OrderItem[]

  @@index([regionId])
  @@index([countryId])
  @@index([isActive])
  @@index([dataType])
  @@index([locationCode])
}

model Order {
  id          Int      @id @default(autoincrement())
  userId      Int?
  user        User?    @relation(fields: [userId], references: [id])
  
  totalAmount Float
  currency    String   @default("USD")
  status      String   @default("pending")
  
  customerName    String?
  customerEmail   String?
  
  esimaccessOrderId     String?
  esimaccessOrderStatus String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems  OrderItem[]

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id              Int     @id @default(autoincrement())
  orderId         Int
  order           Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  planId          String?
  plan            Plan?   @relation(fields: [planId], references: [id])
  
  planName        String
  packageCode     String?
  quantity        Int     @default(1)
  price           Float
  
  esimIccid       String?
  esimEid         String?
  esimTranNo      String?
  esimQrCode      String?
  esimQrImage     String?
  esimLpaString   String?
  activationCode  String?
  
  totalVolume    Float?   // Total data volume in bytes (from API)
  smdpStatus      String?  // RELEASED, DOWNLOADED, INSTALLED, ENABLED
  esimStatus      String?  // INIT, GOT_RESOURCE, ACTIVATED, CANCEL, COMPLETED
  orderUsage      Float?   // Data usage in bytes
  lastUsageSync   DateTime?
  enabledAt       DateTime? // When eSIM was first enabled on device

  @@index([esimIccid])
  @@index([esimTranNo])
  @@index([orderId])
}

model WebhookLog {
  id          Int      @id @default(autoincrement())
  orderNo     String?
  notifyType  String?
  orderStatus String?
  smdpStatus  String?
  payload     Json
  processedAt DateTime @default(now())

  @@index([orderNo])
  @@index([notifyType])
}

model CartItem {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId    String?
  planName  String
  price     Float
  quantity  Int      @default(1)
  createdAt DateTime @default(now())

  @@index([userId])
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String
  image       String?
  category    String?
  author      String?
  isPublished Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([isPublished])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}